<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.chart.PieChart?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.DashboardController"
      alignment="TOP_CENTER"
      spacing="25"
      style="-fx-padding: 40;">

    <Label text="LifeOS Dashboard"
           style="-fx-font-size: 28px; -fx-font-weight: bold;" />

    <!-- Cards -->
    <HBox spacing="25" alignment="CENTER">

        <StackPane style="-fx-background-color: #1e1e1e;
                          -fx-background-radius: 15;
                          -fx-padding: 25;">
            <VBox alignment="CENTER" spacing="8">
                <Label text="Total Tasks"
                       style="-fx-text-fill: #bbbbbb;"/>
                <Label fx:id="totalLabel"
                       style="-fx-font-size: 22px; -fx-text-fill: white;"/>
            </VBox>
        </StackPane>

        <StackPane style="-fx-background-color: #1e1e1e;
                          -fx-background-radius: 15;
                          -fx-padding: 25;">
            <VBox alignment="CENTER" spacing="8">
                <Label text="Completed"
                       style="-fx-text-fill: #bbbbbb;"/>
                <Label fx:id="completedLabel"
                       style="-fx-font-size: 22px; -fx-text-fill: white;"/>
            </VBox>
        </StackPane>

    </HBox>

    <!-- Progress Section -->
    <VBox alignment="CENTER" spacing="10">
        <ProgressBar fx:id="progressBar"
                     prefWidth="400"
                     style="-fx-accent: #00c853;" />
        <Label fx:id="percentageLabel"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    </VBox>

    <!-- Pie Chart -->
    <PieChart fx:id="pieChart"
              prefHeight="350"
              legendVisible="true"
              labelsVisible="true"/>

</VBox>