<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.WorkoutController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- TITLE -->
    <Label text="Workout Module"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- WORKOUT INPUT -->
    <HBox spacing="10">

        <TextField fx:id="exerciseField"
                   promptText="Exercise name..."
                   HBox.hgrow="ALWAYS"/>

        <TextField fx:id="durationField"
                   promptText="Duration (min)"
                   prefWidth="120"/>

        <Button text="Add"
                onAction="#addWorkout"/>

    </HBox>

    <!-- WORKOUT LIST -->
    <ListView fx:id="workoutList"
              VBox.vgrow="ALWAYS"/>

</VBox>