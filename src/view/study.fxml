<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox spacing="20"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.StudyController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- TITLE -->
    <Label text="Study Module"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- SESSION CONTROLS -->
    <HBox spacing="15" alignment="CENTER_LEFT">

        <Label text="Session Timer:"
               style="-fx-font-size: 14px;"/>

        <Label fx:id="timerLabel"
               text="00:00:00"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <Button text="Start"
                onAction="#startSession"/>

        <Button text="Stop"
                onAction="#stopSession"/>

    </HBox>

    <!-- DAILY SUMMARY -->
    <Separator/>

    <VBox spacing="10">
        <Label text="Today's Study Time"
               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

        <Label fx:id="todayHoursLabel"
               text="0 hours"/>
    </VBox>

</VBox>